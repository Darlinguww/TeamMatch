# ══════════════════════════════════════════════════════════════════
# TEAMMATCH — Variables de Entorno
# ══════════════════════════════════════════════════════════════════
# INSTRUCCIONES:
## Cada integrante hace esto UNA SOLA VEZ al clonar el repo
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena los valores marcados con <CAMBIAR>
# Luego abre el .env y reemplaza solo estas 3 líneas:
#JWT_SECRET=pega_aqui_el_resultado_de_openssl -> en consola pon: openssl rand -hex 64
#NEO4J_PASSWORD= Mira el Discord para ver el password que puse en Neo4j
#GEMINI_API_KEY= Mira el Discord para ver el API key que puse en Gemini
#   3. NUNCA commitees el archivo .env al repositorio
# ══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# GENERAL
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─────────────────────────────────────────────
# JWT — Autenticación
# ─────────────────────────────────────────────
# Genera un secreto seguro con: openssl rand -hex 64
JWT_SECRET=<CAMBIAR_POR_SECRETO_SEGURO>
JWT_EXPIRES_IN=24h

# ─────────────────────────────────────────────
# NEO4J — Base de datos de grafos
# ─────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<CAMBIAR_POR_PASSWORD_SEGURO>

# ─────────────────────────────────────────────
# AI SERVICE — Gemini
# ─────────────────────────────────────────────
# Obtén tu API key en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<CAMBIAR_POR_TU_API_KEY>
GEMINI_MODEL=gemini-1.5-flash
AI_SERVICE_URL=http://ai-service:8000

# Límites de seguridad para procesamiento de archivos
MAX_FILE_SIZE_MB=5
PROCESSING_TIMEOUT_MS=30000

# ─────────────────────────────────────────────
# SEGURIDAD — Control de acceso
# ─────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=4
LOGIN_BLOCK_DURATION_MS=900000

# ─────────────────────────────────────────────
# FRONTEND — Vite
# ─────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api